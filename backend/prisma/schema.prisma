generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                   @id @default(uuid())
  email                    String                   @unique
  password                 String?
  name                     String
  bio                      String?
  role                     Role                     @default(PARTICIPANT)
  isVerified               Boolean                  @default(false)
  profilePicture           String?
  resumeUrl                String?
  createdAt                DateTime                 @default(now())
  updatedAt                DateTime                 @updatedAt
  deletedAt                DateTime?
  verificationToken        String?
  verificationTokenExpires DateTime?
  githubUrl                String?
  linkedinUrl              String?
  intrestes                InterestType[]
  techRoles                String[]                 @default([])
  airecommendationMembers  AIRecommendationMember[]
  hackathonInterests       HackathonInterest[]
  createdHackathons        Hackathon[]              @relation("HackathonCreator")
  matchingRequests         MatchingRequest[]
  notifications            Notification[]
  passwordResetTokens      PasswordResetToken[]
  projectInterests         ProjectInterest[]
  ownedProjects            Project[]
  refreshTokens            RefreshToken[]
  receivedInvitations      TeamInvitation[]         @relation("InvitationReceiver")
  sentInvitations          TeamInvitation[]         @relation("InvitationSender")
  teamMemberships          TeamMember[]
  ownedTeams               Team[]                   @relation("TeamOwner")
  skills                   UserSkill[]

  @@index([email])
  @@index([name])
  @@map("users")
}

model Skill {
  id        String      @id @default(uuid())
  name      String      @unique
  createdAt DateTime    @default(now())
  teams     TeamSkill[]
  users     UserSkill[]

  @@map("skills")
}

model UserSkill {
  userId    String
  skillId   String
  createdAt DateTime @default(now())
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@map("user_skills")
}

model Hackathon {
  id                 String              @id @default(uuid())
  title              String
  applyLink          String?
  status             HackathonStatus     @default(UPCOMING)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  location           String?             @default("Online")
  organization       String?
  prizeAmount        Float?              @default(0)
  prizesCounts       Int?                @default(0)
  registrationsCount Int?                @default(0)
  remainingTime      String?
  slug               String?
  submissionPeriod   String?
  thumbnailUrl       String?
  createdBy          String?
  endDate            DateTime?
  interestCount      Int                 @default(0)
  source             HackathonSource     @default(SCRAPED)
  devpostId          String?             @unique
  interests          HackathonInterest[]
  tags               HackathonTag[]
  creator            User?               @relation("HackathonCreator", fields: [createdBy], references: [id])
  matchingRequests   MatchingRequest[]
  teams              Team[]

  @@map("hackathons")
}

model Tag {
  id         String         @id @default(uuid())
  name       String         @unique
  createdAt  DateTime       @default(now())
  hackathons HackathonTag[]

  @@map("tags")
}

model HackathonTag {
  hackathonId String
  tagId       String
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  tag         Tag       @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([hackathonId, tagId])
  @@map("hackathon_tags")
}

model Team {
  id               String            @id @default(uuid())
  name             String
  hackathonId      String
  ownerId          String
  status           TeamStatus        @default(FORMING)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  description      String?
  formationMethod  FormationMethod   @default(AUTO_MATCHED)
  roles            String[]
  size             Int               @default(1)
  matchingRequests MatchingRequest[]
  project          Project?
  invitations      TeamInvitation[]
  members          TeamMember[]
  skills           TeamSkill[]
  hackathon        Hackathon         @relation(fields: [hackathonId], references: [id])
  owner            User              @relation("TeamOwner", fields: [ownerId], references: [id])

  @@map("teams")
}

model TeamSkill {
  teamId  String
  skillId String
  skill   Skill  @relation(fields: [skillId], references: [id], onDelete: Cascade)
  team    Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, skillId])
  @@map("team_skills")
}

model TeamMember {
  teamId   String
  userId   String
  joinedAt DateTime @default(now())
  team     Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model TeamInvitation {
  id                   String                  @id @default(uuid())
  teamId               String
  senderId             String
  receiverId           String
  status               InvitationStatus        @default(PENDING)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt
  deadline             DateTime
  recommendationMember AIRecommendationMember?
  receiver             User                    @relation("InvitationReceiver", fields: [receiverId], references: [id])
  sender               User                    @relation("InvitationSender", fields: [senderId], references: [id])
  team                 Team                    @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("team_invitations")
}

model MatchingRequest {
  id              String             @id @default(uuid())
  userId          String
  hackathonId     String
  status          MatchingStatus     @default(PENDING)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  projectId       String?
  queuePosition   Int?
  roundNumber     Int                @default(1)
  teamId          String?
  recommendations AIRecommendation[]
  hackathon       Hackathon          @relation(fields: [hackathonId], references: [id])
  project         Project?           @relation(fields: [projectId], references: [id])
  team            Team?              @relation(fields: [teamId], references: [id])
  user            User               @relation(fields: [userId], references: [id])

  @@map("matching_requests")
}

model AIRecommendation {
  id                      String                   @id @default(uuid())
  matchingRequestId       String
  teamData                Json
  status                  RecommendationStatus     @default(PENDING)
  createdAt               DateTime                 @default(now())
  expiresAt               DateTime?
  airecommendationMembers AIRecommendationMember[]
  matchingRequest         MatchingRequest          @relation(fields: [matchingRequestId], references: [id], onDelete: Cascade)

  @@map("ai_recommendations")
}

model AIRecommendationMember {
  id               String           @id @default(uuid())
  recommendationId String
  userId           String
  status           InvitationStatus @default(PENDING)
  createdAt        DateTime         @default(now())
  invitationId     String?          @unique
  invitation       TeamInvitation?  @relation(fields: [invitationId], references: [id])
  recommendation   AIRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([recommendationId, userId])
  @@map("ai_recommendation_members")
}

model AIIdentityMap {
  id         Int      @id @default(autoincrement())
  entityId   String
  entityType String
  createdAt  DateTime @default(now())

  @@unique([entityId, entityType])
  @@map("ai_identity_maps")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  isUsed    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}

model HackathonInterest {
  userId      String
  hackathonId String
  createdAt   DateTime  @default(now())
  hackathon   Hackathon @relation(fields: [hackathonId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, hackathonId])
  @@map("hackathon_interests")
}

model Project {
  id               String            @id @default(uuid())
  title            String
  description      String
  ownerId          String
  teamId           String            @unique
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  interestsCount   Int               @default(0)
  matchingRequests MatchingRequest[]
  interests        ProjectInterest[]
  owner            User              @relation(fields: [ownerId], references: [id])
  team             Team              @relation(fields: [teamId], references: [id])

  @@map("projects")
}

model ProjectInterest {
  userId    String
  projectId String
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
  @@map("project_interests")
}

enum Role {
  PARTICIPANT
  ADMIN
}

enum TeamStatus {
  FORMING
  COMPLETE
}

enum FormationMethod {
  MANUAL
  AUTO_MATCHED
  INVITED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
  CANCELLED
}

enum MatchingStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum RecommendationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum HackathonStatus {
  UPCOMING
  ONGOING
  ENDED
}

enum NotificationType {
  TEAM_INVITE
  MATCH_FOUND
  INVITE_ACCEPTED
  INVITE_REJECTED
  HACKATHON_REMINDER
  RECOMMENDATION_RECEIVED
  /// to tell the owner if he has missing in his currect team
  ROUND2_AVAILABLE
}

enum HackathonSource {
  SCRAPED
  USER_CREATED
}

enum InterestType {
  AR_VR                       @map("AR/VR")
  BEGINNER_FRIENDLY           @map("Beginner Friendly")
  BLOCKCHAIN                  @map("Blockchain")
  COMMUNICATION               @map("Communication")
  CYBERSECURITY               @map("Cybersecurity")
  DATABASES                   @map("Databases")
  DESIGN                      @map("Design")
  DEVOPS                      @map("DevOps")
  ECOMMERCE_RETAIL            @map("E-commerce/Retail")
  EDUCATION                   @map("Education")
  ENTERPRISE                  @map("Enterprise")
  FINTECH                     @map("Fintech")
  GAMING                      @map("Gaming")
  HEALTH                      @map("Health")
  IOT                         @map("IoT")
  LIFEHACKS                   @map("Lifehacks")
  LOW_NO_CODE                 @map("Low/No Code")
  MACHINE_LEARNING_AI         @map("Machine Learning/AI")
  MOBILE                      @map("Mobile")
  MUSIC_ART                   @map("Music/Art")
  OPEN_ENDED                  @map("Open Ended")
  PRODUCTIVITY                @map("Productivity")
  QUANTUM                     @map("Quantum")
  ROBOTIC_PROCESS_AUTOMATION  @map("Robotic Process Automation")
  SERVERLESS                  @map("Serverless")
  SOCIAL_GOOD                 @map("Social Good")
  VOICE_SKILLS                @map("Voice skills")
  WEB                         @map("Web")
}
